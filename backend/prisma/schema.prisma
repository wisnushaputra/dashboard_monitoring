generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("viewer") // admin, operator, viewer
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  shiftLogs    ShiftLog[]

  @@map("users")
}

model Customer {
  id                   Int      @id @default(autoincrement())
  name                 String   @unique
  code                 String   @unique
  slaTarget            Float    @default(99.5) @map("sla_target") // e.g. 99.9, 99.5, 99.0
  monthlyFee           Float    @default(15000000) @map("monthly_fee") // Monthly contract fee in IDR
  penaltyRatePerPercent Float   @default(5.0) @map("penalty_rate_per_percent") // % refund per 0.1% SLA breach
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  sites                Site[]
  nodes                Node[]
  slaBillingSnapshots  SlaBillingSnapshot[]

  @@map("customers")
}

model Site {
  id         Int      @id @default(autoincrement())
  name       String
  location   String?
  customerId Int      @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  nodes      Node[]

  @@unique([name, customerId])
  @@map("sites")
}

model Node {
  id                Int      @id @default(autoincrement())
  name              String
  ipAddress         String   @map("ip_address")
  deviceType        String   @default("router") @map("device_type") // router, switch, firewall, server, olt, ap, etc
  location          String?
  description       String?
  monitoringInterval Int     @default(30) @map("monitoring_interval") // seconds
  monitorType       String   @default("icmp") @map("monitor_type") // icmp, snmp, http, tcp
  monitorConfig     Json?    @map("monitor_config")
  status            String   @default("unknown") // up, down, warning, unknown
  latencyMs         Float?   @map("latency_ms")
  minLatencyMs      Float?   @map("min_latency_ms")
  maxLatencyMs      Float?   @map("max_latency_ms")
  jitterMs          Float?   @map("jitter_ms")
  packetLoss        Float?   @map("packet_loss")
  lastChecked       DateTime? @map("last_checked")
  enabled           Boolean  @default(true)
  isMaintenance      Boolean  @default(false) @map("is_maintenance")
  x                 Float?   // canvas position for topology
  y                 Float?
  customerId        Int      @map("customer_id")
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  siteId            Int?     @map("site_id")
  site              Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  alarms            Alarm[]
  eventLogs         EventLog[]
  connectionsFrom   Connection[] @relation("from_node")
  connectionsTo     Connection[] @relation("to_node")
  maintenanceWindows MaintenanceWindow[]
  deviceConfigs     DeviceConfig[]
  anomalyLogs       AnomalyLog[]
  rcaReports        RcaReport[]
  parentId          Int?     @map("parent_id")
  parent            Node?    @relation("ParentChild", fields: [parentId], references: [id], onDelete: Cascade)
  children          Node[]   @relation("ParentChild")

  @@map("nodes")
}

model Connection {
  id          Int      @id @default(autoincrement())
  fromNodeId  Int      @map("from_node_id")
  toNodeId    Int      @map("to_node_id")
  sourceHandle String?  @map("source_handle")
  targetHandle String?  @map("target_handle")
  label       String?
  color       String?  @default("#94a3b8")
  fromNode    Node     @relation("from_node", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode      Node     @relation("to_node", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@map("connections")
}

model Topology {
  id        Int      @id @default(autoincrement())
  name      String
  data      Json?    // stores full canvas state (nodes positions, connections)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("topologies")
}

model Alarm {
  id          Int       @id @default(autoincrement())
  nodeId      Int       @map("node_id")
  node        Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  status      String    @default("active") // active, resolved
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  duration    Int?      // seconds
  cause       String?
  recoveryNote String?  @map("recovery_note")
  rcaReports  RcaReport[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("alarms")
}

model EventLog {
  id        Int      @id @default(autoincrement())
  nodeId    Int      @map("node_id")
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  eventType String   @map("event_type") // up, down, warning
  message   String?
  latencyMs Float?   @map("latency_ms")
  minLatencyMs Float? @map("min_latency_ms")
  maxLatencyMs Float? @map("max_latency_ms")
  jitterMs     Float? @map("jitter_ms")
  packetLoss Float?   @map("packet_loss")
  timestamp DateTime @default(now())

  @@map("event_logs")
}

model NotificationSetting {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  soundEnabled Boolean @default(true) @map("sound_enabled")
  emailEnabled Boolean @default(false) @map("email_enabled")
  emailAddress String? @map("email_address")
  webhookEnabled Boolean @default(false) @map("webhook_enabled")
  webhookUrl  String? @map("webhook_url")
  slackEnabled Boolean @default(false) @map("slack_enabled")
  slackWebhook String? @map("slack_webhook")
  telegramEnabled Boolean @default(false) @map("telegram_enabled")
  telegramBotToken String? @map("telegram_bot_token")
  telegramChatId String? @map("telegram_chat_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model MaintenanceWindow {
  id          Int      @id @default(autoincrement())
  nodeId      Int      @map("node_id")
  node        Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  startTime   DateTime @map("start_time")
  endTime     DateTime @map("end_time")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("maintenance_windows")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  username  String
  action    String
  target    String?
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model DeviceConfig {
  id           Int      @id @default(autoincrement())
  nodeId       Int      @map("node_id")
  node         Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  version      Int
  content      String   @db.Text
  hash         String
  changesCount Int      @default(0) @map("changes_count")
  status       String   @default("success") // success, failed
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("device_configs")
}

model AnomalyLog {
  id           Int      @id @default(autoincrement())
  nodeId       Int      @map("node_id")
  node         Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  anomalyType  String   @map("anomaly_type") // latency_spike, slow_degradation, jitter_anomaly
  severity     String   // warning, critical
  zScore       Float    @map("z_score")
  currentValue Float    @map("current_value")
  baselineAvg  Float    @map("baseline_avg")
  message      String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("anomaly_logs")
}

model RcaReport {
  id                   Int       @id @default(autoincrement())
  ticketId             String    @unique @map("ticket_id")
  title                String
  nodeId               Int       @map("node_id")
  node                 Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  alarmId              Int?      @map("alarm_id")
  alarm                Alarm?    @relation(fields: [alarmId], references: [id], onDelete: SetNull)
  incidentStartTime    DateTime  @map("incident_start_time")
  incidentEndTime      DateTime? @map("incident_end_time")
  durationMinutes      Int       @default(0) @map("duration_minutes")
  severity             String    @default("major") // critical, major, minor
  rootCauseCategory    String    @map("root_cause_category") // fiber_cut, hardware_failure, power_outage, software_bug, human_error, third_party
  rootCauseDescription String    @db.Text @map("root_cause_description")
  executiveSummary     String    @db.Text @map("executive_summary")
  chronologyJson       String    @db.Text @map("chronology_json") // JSON array of [{ timestamp, description }]
  actionItemsJson      String    @db.Text @map("action_items_json") // JSON array of [{ action, owner, dueDate, status }]
  authorName           String    @default("NOC Operations Team") @map("author_name")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("rca_reports")
}

model ShiftLog {
  id                    Int       @id @default(autoincrement())
  shiftName             String    @map("shift_name") // morning, afternoon, night
  shiftDate             DateTime  @map("shift_date")
  outgoingUserId        Int       @map("outgoing_user_id")
  outgoingUser          User      @relation(fields: [outgoingUserId], references: [id], onDelete: Cascade)
  incomingOperatorName  String    @map("incoming_operator_name")
  openIncidentsCount    Int       @default(0) @map("open_incidents_count")
  resolvedIncidentsCount Int      @default(0) @map("resolved_incidents_count")
  maintenanceNotes      String?   @db.Text @map("maintenance_notes")
  pendingActionItems    String?   @db.Text @map("pending_action_items")
  handoverSummary       String    @db.Text @map("handover_summary")
  status                String    @default("submitted") // submitted, acknowledged
  acknowledgedBy        String?   @map("acknowledged_by")
  acknowledgedAt        DateTime? @map("acknowledged_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  @@map("shift_logs")
}

model SlaBillingSnapshot {
  id                     Int      @id @default(autoincrement())
  monthYear              String   @map("month_year") // e.g. "2026-07"
  customerId             Int      @map("customer_id")
  customer               Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contractedSla          Float    @map("contracted_sla")
  actualUptimePct        Float    @map("actual_uptime_pct")
  totalDowntimeMinutes   Float    @map("total_downtime_minutes")
  allowedDowntimeMinutes Float    @map("allowed_downtime_minutes")
  excessDowntimeMinutes  Float    @map("excess_downtime_minutes")
  monthlyFee             Float    @map("monthly_fee")
  penaltyPct             Float    @map("penalty_pct")
  penaltyAmountIdr       Float    @map("penalty_amount_idr")
  netBillAmountIdr       Float    @map("net_bill_amount_idr")
  status                 String   @default("calculated") // calculated, approved, invoiced
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([customerId, monthYear])
  @@map("sla_billing_snapshots")
}
